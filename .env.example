# Translation (OpenAI-compatible Chat Completions)
#
# Used by the background translation workers in the Web UI.
# Base URL must point to an OpenAI-compatible API that implements:
#   POST {TRANSLATE_API_BASE_URL}/chat/completions
#
# Copy this file to `.env` and fill in real values.

# OpenAI-compatible base URL (default: https://api.openai.com/v1)
TRANSLATE_API_BASE_URL=https://api.openai.com/v1

# API key (leave empty if your proxy doesn't require auth)
TRANSLATE_API_KEY=

# Model name (default: gpt-4.1-mini)
TRANSLATE_MODEL=gpt-4.1-mini

# Sampling controls
TRANSLATE_TEMPERATURE=0.1

# Network / retry
TRANSLATE_TIMEOUT_S=60
TRANSLATE_MAX_RETRIES=2

# Internal prompt version (leave default unless you know why)
TRANSLATE_PROMPT_VERSION=translate_v1

# Optional: number of translation worker threads for the Web UI (1..6, default: 2)
# TRANSLATE_WORKERS=2
