# Translation (OpenAI-compatible Chat Completions)
#
# Used by the background translation workers in the Web UI.
# Base URL must point to an OpenAI-compatible API that implements:
#   POST {TRANSLATE_API_BASE_URL}/chat/completions
#
# Copy this file to `.env` and fill in real values.

# OpenAI-compatible base URL (default: https://api.openai.com/v1)
TRANSLATE_API_BASE_URL=https://api.openai.com/v1

# API key (leave empty if your proxy doesn't require auth)
TRANSLATE_API_KEY=

# Model name (default: gpt-4.1-mini)
TRANSLATE_MODEL=gpt-4.1-mini

# Sampling controls
TRANSLATE_TEMPERATURE=0.1

# Network / retry
TRANSLATE_TIMEOUT_S=60
TRANSLATE_MAX_RETRIES=2

# Per-region translate: HTTP timeouts (seconds) per attempt, escalating on timeout soft-locks (comma-separated).
# Example: 5s then 10s then 20s… Default below if unset.
# TRANSLATE_REGION_ATTEMPT_TIMEOUTS_S=5,10,20,40,80

# During PDF OCR (generate_worker subprocess), cap translation concurrency further so OCR + translate do not overload the API/GPU (1..5, default 2). Set to 5 only if your gateway handles it.
# TRANSLATE_WORKERS_IN_GENERATION=2

# Internal prompt version (leave default unless you know why)
TRANSLATE_PROMPT_VERSION=translate_v1

# Max concurrent translation API requests / worker threads for the Web UI (1..5, default: 5).
# Matches typical upstream limits; use CLI --translate-workers to override per run.
TRANSLATE_WORKERS=5
